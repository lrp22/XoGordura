{
  "expo": {
    "scheme": "XoGordura",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "icon": "./assets/images/cat-logo.png",
    "splash": {
      "image": "./assets/images/fitness-cat.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "bundler": "metro"
    },
    "name": "XoGordura",
    "slug": "XoGordura",
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "android": {
      "package": "com.anonymous.XoGordura"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.XoGordura"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1e7e1c5-3ddc-4377-9cf1-d5df7b31b53c"
      }
    }
  }
}
